{
    "name": "illuma-law/laravel-social-caster",
    "description": "A standalone Laravel package for social media publishing.",
    "license": "MIT",
    "authors": [
        {
            "name": "Illuma Law",
            "email": "hello@illumalaw.com"
        }
    ],
    "require": {
        "php": "^8.5",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "spatie/laravel-package-tools": "^1.16",
        "saloonphp/saloon": "^3.0|^4.0",
        "saloonphp/laravel-plugin": "^3.0|^4.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.1|^9.0",
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "spatie/laravel-ray": "^1.35"
    },
    "autoload": {
        "psr-4": {
            "Illuma\\SocialCaster\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Illuma\\SocialCaster\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Illuma\\SocialCaster\\SocialCasterServiceProvider"
            ],
            "aliases": {
                "SocialCaster": "Illuma\\SocialCaster\\Facades\\SocialCaster"
            }
        }
    }
}
